TELEGRAM_BOT_TOKEN=<token de @BotFather>
GEMINI_API_KEY=<tu API key de Google AI Studio>
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_MAX_OUTPUT_TOKENS=500
GEMINI_MAX_OUTPUT_TOKENS_MULTIMODAL=700
GEMINI_TRANSCRIPTION_MAX_OUTPUT_TOKENS=350
GEMINI_TEMPERATURE=0.1
MYSQL_HOST=localhost
MYSQL_USER=finbot
MYSQL_PASSWORD=<contraseña segura>
MYSQL_DATABASE=finbot
ALLOWED_USER_IDS=<tu Telegram user ID>

# Bitácora de soporte
SUPPORT_DEFAULT_RESPONSIBLE=Miguel
SUPPORT_TICKET_START=1001
SUPPORT_EXPORT_TEMPLATE_PATH="/home/usuario/app/templates/FO-TI-03 Bitacora de Soporte 2026.xlsx"
SUPPORT_EXPORT_DIR=/home/usuario/app/exports/support
SUPPORT_EXPORT_EMAIL_TO=carlos.guizarp@gmail.com

# SMTP para enviar bitácoras por correo (cPanel, Gmail App Password u otro proveedor SMTP)
SMTP_HOST=mail.tudominio.com
SMTP_PORT=465
SMTP_USER=soporte@tudominio.com
SMTP_PASSWORD=<password o app password>
SMTP_FROM=soporte@tudominio.com

# Audio general
